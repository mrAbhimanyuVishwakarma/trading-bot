{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Check Git Status",
			"type": "shell",
			"command": "git",
			"args": [
				"status"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Git Add All",
			"type": "shell",
			"command": "git",
			"args": [
				"add",
				"."
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Git Commit",
			"type": "shell",
			"command": "git",
			"args": [
				"commit",
				"-m",
				"Complete minimal trading bot with backtest and double-click startup"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Check Git Remotes",
			"type": "shell",
			"command": "git",
			"args": [
				"remote",
				"-v"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Add GitHub Remote",
			"type": "shell",
			"command": "git",
			"args": [
				"remote",
				"add",
				"origin",
				"https://github.com/AxeDude7/trading-bot.git"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Push to GitHub",
			"type": "shell",
			"command": "git",
			"args": [
				"push",
				"-u",
				"origin",
				"main"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Final Git Status Check",
			"type": "shell",
			"command": "git",
			"args": [
				"status"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Add VS Code Tasks",
			"type": "shell",
			"command": "git",
			"args": [
				"add",
				".vscode/tasks.json"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		}
	]
}